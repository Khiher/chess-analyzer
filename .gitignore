# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
out/
dist/
dist-electron/
*.tsbuildinfo

# Native engine binaries (downloaded/placed per-platform, not committed)
resources/engines/*
!resources/engines/.gitkeep
!resources/engines/README.md

# Local model files (downloaded on first use, never committed)
resources/models/*
!resources/models/.gitkeep

# Test / coverage
coverage/
.vitest/

# Logs
*.log
npm-debug.log*
logs/

# Editor / OS
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db

# Env / secrets
.env
.env.*
!.env.example

# Local user data produced at runtime
userData/
