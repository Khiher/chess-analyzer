{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022"],
    "types": ["node", "electron-vite/node"],
    "outDir": "./out/types-node"
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "src/core/**/*.ts",
    "electron.vite.config.ts"
  ],
  "exclude": ["src/**/__tests__/**", "src/**/*.test.ts"]
}
