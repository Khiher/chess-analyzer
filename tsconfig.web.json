{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node"],
    "outDir": "./out/types-web"
  },
  "include": [
    "src/renderer/src/**/*.ts",
    "src/renderer/src/**/*.tsx",
    "src/shared/**/*.ts",
    "src/core/**/*.ts",
    "src/preload/index.d.ts"
  ],
  "exclude": ["src/**/__tests__/**", "src/**/*.test.ts"]
}
